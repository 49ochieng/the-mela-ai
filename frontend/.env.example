# ============================================================
# Mela AI Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local with real values.
# ============================================================

# ── Entra ID — Login / Auth app registration ─────────────────
# Use the CLIENT ID of the dedicated LOGIN app registration (NOT the data app).
# This app must be configured as Single-page application (SPA) in Azure portal.
# Redirect URIs (SPA platform):
#   http://localhost:3005                        ← local dev
#   https://armely-ai-web.azurewebsites.net/     ← production
#
# NEXT_PUBLIC_ENTRA_AUTH_CLIENT_ID is preferred; NEXT_PUBLIC_AZURE_AD_CLIENT_ID
# is kept as a fallback so existing single-registration deployments still work.
NEXT_PUBLIC_ENTRA_AUTH_CLIENT_ID=<login-app-registration-client-id>
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=<login-app-registration-client-id>
NEXT_PUBLIC_AZURE_AD_TENANT_ID=<azure-ad-tenant-id>

# Redirect URI — must exactly match a registered SPA redirect URI in the portal.
# For local dev: http://localhost:3005 (origin only, no path suffix).
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3005

# API scope — must match the scope exposed on the LOGIN app registration.
# Azure portal: App registrations → <login-app> → Expose an API → access_as_user
# Format: api://<NEXT_PUBLIC_ENTRA_AUTH_CLIENT_ID>/access_as_user
NEXT_PUBLIC_API_SCOPE=api://<login-app-client-id>/access_as_user

# ── Dev login (only exposed in development mode builds) ──────
NEXT_PUBLIC_DEV_USERNAME=<dev-username>
NEXT_PUBLIC_DEV_PASSWORD=<dev-password>

# ── API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_VERSION=v1

# ── App branding ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Mela AI
NEXT_PUBLIC_ORG_NAME=Armely
NEXT_PUBLIC_PRIMARY_COLOR=#2f5597

# ── Feature flags ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true
NEXT_PUBLIC_ENABLE_AGENTS=true
NEXT_PUBLIC_ENABLE_RAG=true
NEXT_PUBLIC_ENABLE_TRANSLATION=true
NEXT_PUBLIC_ENABLE_IMAGE_GENERATION=true
NEXT_PUBLIC_ENABLE_DOCUMENT_INTELLIGENCE=true

# ── Analytics (optional) ──────────────────────────────────────
NEXT_PUBLIC_APP_INSIGHTS_KEY=
NEXT_PUBLIC_ENABLE_ANALYTICS=false
