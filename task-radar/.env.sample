# Mela Task Radar — worker configuration
# Copy to .env and fill in. NEVER commit the filled-in .env.

# MCP key Mela presents on every inbound POST / call (X-Api-Key header).
# Must equal TASK_RADAR_MCP_API_KEY in Mela's backend env.
TASK_RADAR_MCP_API_KEY=

# Key this worker presents to Mela on /api/v1/ingest/* callbacks
# (X-Worker-Api-Key header). Must equal TASK_RADAR_INBOUND_API_KEY in Mela's
# backend env (stored on the worker manifest's auth_config.inbound_api_key).
TASK_RADAR_INBOUND_API_KEY=

# Default Microsoft Planner plan to create tasks in when the caller doesn't
# specify one. Find via Graph Explorer: GET /groups/{groupId}/planner/plans
TASK_RADAR_PLANNER_PLAN_ID=

# Base URL of the Mela backend the worker POSTs callbacks to.
# Local: http://localhost:8000   Prod: https://armely-ai-api.azurewebsites.net
MELA_INGESTION_BASE_URL=

# Azure app registration (app-only / client-credentials) used to call Graph.
# Reuse Mela's enterprise app (same AZURE_CLIENT_ID) — needs Tasks.ReadWrite
# (Group.ReadWrite.All) application permission with admin consent.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Port the worker listens on.
PORT=8001
