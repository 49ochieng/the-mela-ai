# ============================================================
# Mela Task Radar — Azure Dev Deployment | SAMPLE TEMPLATE
# Copy to .env.dev and fill in real values, OR paste each key
# directly into Azure App Service → Configuration → App Settings.
# NEVER commit .env.dev with real values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
FRONTEND_URL=https://<your-dev-web>.azurewebsites.net
BACKEND_URL=https://<your-dev-api>.azurewebsites.net

# ── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-random-64-char-hex-string>
JWT_SECRET=<generate-a-random-64-char-hex-string>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=<32-byte-url-safe-base64>

# ── Database (Azure SQL recommended for dev) ─────────────────
DATABASE_URL=mssql+aioodbc://<user>:<password>@<server>.database.windows.net/<db>?driver=ODBC+Driver+18+for+SQL+Server

# ── Microsoft Entra ID (Auth + Graph delegated) ──────────────
# Create a confidential Web app registration:
#   Platform: Web
#   Redirect URI: https://<your-dev-api>.azurewebsites.net/api/auth/microsoft/callback
#   Delegated permissions: openid, profile, offline_access, User.Read,
#                          Mail.Read, Files.ReadWrite, Tasks.ReadWrite, Group.Read.All
#   Grant admin consent.
AZURE_TENANT_ID=<azure-ad-tenant-id>
AZURE_CLIENT_ID=<task-radar-app-client-id>
AZURE_CLIENT_SECRET=<task-radar-app-client-secret>
MICROSOFT_REDIRECT_URI=https://<your-dev-api>.azurewebsites.net/api/auth/microsoft/callback
GRAPH_SCOPES=openid profile offline_access User.Read Mail.Read Files.ReadWrite Tasks.ReadWrite Group.Read.All Team.ReadBasic.All Channel.ReadBasic.All ChannelMessage.Read.All

# ── Azure OpenAI (GPT-5.2) ───────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=<azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT_GPT52=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Storage (attachment archival) ────────────────────────────
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=taskradar-attachments

# ── Queue ────────────────────────────────────────────────────
# In dev with one App Service instance you can use 'memory'.
# For multi-instance / production, use Service Bus.
QUEUE_PROVIDER=servicebus
AZURE_SERVICE_BUS_CONNECTION_STRING=<service-bus-connection-string>
AZURE_SERVICE_BUS_QUEUE=taskradar-scans

# ── Key Vault ────────────────────────────────────────────────
KEY_VAULT_URL=https://<vault-name>.vault.azure.net/

# ── MCP server ───────────────────────────────────────────────
MCP_SERVER_URL=https://<your-dev-mcp>.azurewebsites.net
MCP_API_KEY=<long-random-shared-secret>

# ── Feature flags ────────────────────────────────────────────
# Phase 2 (off for MVP): Teams scan + realtime webhooks
ENABLE_TEAMS_SCAN=false
ENABLE_EXCEL_SYNC=true
ENABLE_PLANNER_SYNC=true
ENABLE_MCP_SERVER=true
ENABLE_REALTIME_WEBHOOKS=false

# ── Observability ────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...
