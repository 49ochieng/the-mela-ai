# ============================================================
# Mela Task Radar — Production | SAMPLE TEMPLATE
# In production, set these as Azure App Service Application Settings
# or reference them from Azure Key Vault using @Microsoft.KeyVault(...).
# NEVER commit a .env.prod with real values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
FRONTEND_URL=https://<your-domain>
BACKEND_URL=https://<your-api-domain>

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/SECRET-KEY/)
JWT_SECRET=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/JWT-SECRET/)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
TOKEN_ENCRYPTION_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/TOKEN-ENCRYPTION-KEY/)

# ── Database (Azure SQL) ─────────────────────────────────────
DATABASE_URL=mssql+aioodbc://<user>:<password>@<server>.database.windows.net/<db>?driver=ODBC+Driver+18+for+SQL+Server

# ── Microsoft Entra ID (Auth + Graph delegated) ──────────────
AZURE_TENANT_ID=<azure-ad-tenant-id>
AZURE_CLIENT_ID=<task-radar-app-client-id>
AZURE_CLIENT_SECRET=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/AZURE-CLIENT-SECRET/)
MICROSOFT_REDIRECT_URI=https://<your-api-domain>/api/auth/microsoft/callback
GRAPH_SCOPES=openid profile offline_access User.Read Mail.Read Files.ReadWrite Tasks.ReadWrite Group.Read.All Team.ReadBasic.All Channel.ReadBasic.All ChannelMessage.Read.All

# ── Azure OpenAI (GPT-5.2) ───────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/AZURE-OPENAI-API-KEY/)
AZURE_OPENAI_DEPLOYMENT_GPT52=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Storage (attachment archival) ────────────────────────────
AZURE_BLOB_CONNECTION_STRING=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/AZURE-BLOB-CONNECTION-STRING/)
AZURE_BLOB_CONTAINER=taskradar-attachments

# ── Queue (Service Bus) ──────────────────────────────────────
QUEUE_PROVIDER=servicebus
AZURE_SERVICE_BUS_CONNECTION_STRING=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/SERVICE-BUS-CONNECTION-STRING/)
AZURE_SERVICE_BUS_QUEUE=taskradar-scans

# ── Key Vault ────────────────────────────────────────────────
KEY_VAULT_URL=https://<vault-name>.vault.azure.net/

# ── MCP server ───────────────────────────────────────────────
MCP_SERVER_URL=https://<your-mcp-domain>
# NOTE: there is no shared MCP API key in production — each Mela user
# mints a per-user agent token from the web UI (Settings → Mela
# connection). Tokens are sent as `Authorization: Bearer mtr_at_…`.

# ── Feature flags ────────────────────────────────────────────
ENABLE_TEAMS_SCAN=false
ENABLE_EXCEL_SYNC=true
ENABLE_PLANNER_SYNC=true
ENABLE_MCP_SERVER=true
ENABLE_REALTIME_WEBHOOKS=false

# ── Observability ────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...
