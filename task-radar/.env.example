# ── App ──────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:2005
BACKEND_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# 32-byte url-safe base64 (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Database ─────────────────────────────────────────────────
# Local dev (SQLite): sqlite+aiosqlite:///./taskradar.db
# Azure SQL:          mssql+aioodbc://USER:PASS@SERVER.database.windows.net/DB?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=sqlite+aiosqlite:///./taskradar.db

# ── Microsoft Entra ID (Auth + Graph) ────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback
GRAPH_SCOPES=openid profile offline_access User.Read Mail.Read Files.ReadWrite Tasks.ReadWrite Group.Read.All

# ── Azure OpenAI (GPT-5.2) ───────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_GPT52=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Storage ──────────────────────────────────────────────────
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=taskradar-attachments
LOCAL_STORAGE_PATH=./storage

# ── Queue ────────────────────────────────────────────────────
# memory   = in-process (dev only — API runs the worker for you)
# servicebus = production (run worker / scheduler / mcp as separate processes)
QUEUE_PROVIDER=memory
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE=taskradar-scans

# ── Key Vault (prod) ─────────────────────────────────────────
KEY_VAULT_URL=

# ── MCP ──────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8090
MCP_API_KEY=change-me
# Phase 2 (off for MVP): Teams scan + realtime webhooks
ENABLE_TEAMS_SCAN=fals
# ── Feature flags ────────────────────────────────────────────
ENABLE_TEAMS_SCAN=true
ENABLE_EXCEL_SYNC=true
ENABLE_PLANNER_SYNC=true
ENABLE_MCP_SERVER=true
ENABLE_REALTIME_WEBHOOKS=false

# ── Observability ────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
