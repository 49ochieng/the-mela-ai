# =============================================================================
# MELA AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Mela AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Azure Settings
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-mela-ai
AZURE_LOCATION=eastus

# -----------------------------------------------------------------------------
# Microsoft Entra ID (Azure AD) Authentication
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Frontend MSAL Configuration
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-frontend-client-id
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000

# API Scopes
NEXT_PUBLIC_API_SCOPE=api://mela-ai-api/access_as_user

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Model Deployments
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# -----------------------------------------------------------------------------
# Azure AI Search
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_INDEX_NAME=mela-documents

# -----------------------------------------------------------------------------
# Azure SQL Database
# -----------------------------------------------------------------------------
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=mela-ai-db
AZURE_SQL_USERNAME=mela-admin
AZURE_SQL_PASSWORD=your-sql-password

# Connection string (auto-constructed or specify directly)
# DATABASE_URL=mssql+pyodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server

# -----------------------------------------------------------------------------
# Azure Blob Storage
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=melaaistorage
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_DOCUMENTS=documents
AZURE_STORAGE_CONTAINER_UPLOADS=uploads

# -----------------------------------------------------------------------------
# Azure Speech Services
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# -----------------------------------------------------------------------------
# Azure Key Vault
# -----------------------------------------------------------------------------
AZURE_KEY_VAULT_NAME=kv-mela-ai
AZURE_KEY_VAULT_URL=https://kv-mela-ai.vault.azure.net/

# -----------------------------------------------------------------------------
# Azure Application Insights
# -----------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string
AZURE_APP_INSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# -----------------------------------------------------------------------------
# Microsoft Graph API
# -----------------------------------------------------------------------------
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0
GRAPH_SCOPES=User.Read,Mail.Send,Mail.ReadWrite,Calendars.ReadWrite,Tasks.ReadWrite,OnlineMeetings.ReadWrite,Files.ReadWrite.All,Sites.Read.All

# -----------------------------------------------------------------------------
# Backend API Settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://mela-ai.azurewebsites.net

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Mela AI
NEXT_PUBLIC_ORGANIZATION=Armely
NEXT_PUBLIC_THEME_COLOR=#2f5597

# -----------------------------------------------------------------------------
# RAG Pipeline Settings
# -----------------------------------------------------------------------------
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Token Limits per User
DEFAULT_DAILY_TOKEN_LIMIT=100000
ADMIN_DAILY_TOKEN_LIMIT=500000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_VOICE=true
ENABLE_FILE_UPLOAD=true
ENABLE_AGENTS=true
ENABLE_SHAREPOINT_SYNC=true

# -----------------------------------------------------------------------------
# SharePoint Integration
# -----------------------------------------------------------------------------
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_DRIVE_ID=your-drive-id
SHAREPOINT_SYNC_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# Redis Cache (Optional)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Set to true to use mock services in development
USE_MOCK_SERVICES=false
