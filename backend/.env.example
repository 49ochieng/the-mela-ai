# Mela AI Backend - Local Development Environment
# Copy to .env and fill in values

# Application
APP_NAME=Mela AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Azure AD Authentication
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure DALL-E (Image Generation)
AZURE_DALLE_ENDPOINT=https://your-dalle.openai.azure.com/
AZURE_DALLE_API_KEY=your-dalle-api-key
AZURE_DALLE_API_VERSION=2024-02-01
AZURE_DALLE_DEPLOYMENT=dall-e-3

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-form-recognizer.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# Azure Translator
AZURE_TRANSLATOR_KEY=your-translator-key
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_DOCUMENT_ENDPOINT=https://your-translator.cognitiveservices.azure.com/
AZURE_TRANSLATOR_REGION=eastus

# Azure SQL Database
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=mela-ai-db
AZURE_SQL_USERNAME=sqladmin
AZURE_SQL_PASSWORD=your-password
# Or use a full connection string:
# DATABASE_URL=mssql+aioodbc://user:pass@server/db?driver=ODBC+Driver+18+for+SQL+Server

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_DOCUMENTS=documents
AZURE_STORAGE_CONTAINER_UPLOADS=uploads

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-key
AZURE_COSMOS_DATABASE=mela-ai
AZURE_COSMOS_CONTAINER=conversations

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX_NAME=mela-documents

# Azure Speech Service
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_ENDPOINT=https://your-speech.cognitiveservices.azure.com/
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# Azure Key Vault
AZURE_KEY_VAULT_NAME=your-keyvault-name
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Ops Alerts
# Primary fallback recipient when ALERT_ADMIN_EMAILS is blank
ALERT_ADMIN_EMAIL=edgar.mcochieng@armely.com
# Optional list of recipients (comma/semicolon-separated)
ALERT_ADMIN_EMAILS=
ALERT_ENABLED=true
ALERT_COOLDOWN_MINUTES=10
ALERT_EMAIL_MAX_ATTEMPTS=3
ALERT_EMAIL_BACKOFF_SECONDS=1.5
# Sender mailbox used by Microsoft Graph app-only sendMail
GRAPH_SENDER_EMAIL=
# Teams webhook is used for high-severity alerts when configured
ALERT_TEAMS_ENABLED=true
ALERT_TEAMS_WEBHOOK_URL=
ALERT_TEAMS_MIN_SEVERITY=critical
# Include remediation suggestions in alert payloads
ALERT_AI_REMEDIATION_ENABLED=true

# CORS
CORS_ORIGINS=["http://localhost:3005","http://localhost:3000"]

# Feature Flags
ENABLE_RAG=true
ENABLE_AGENTS=true
ENABLE_VOICE=true
ENABLE_SHAREPOINT_SYNC=false
ENABLE_TRANSLATION=true
ENABLE_IMAGE_GENERATION=true
ENABLE_DOCUMENT_INTELLIGENCE=true

# ── Orchestration Brain — registered worker apps ───────────────
# Each worker is a fully independent app Mela orchestrates over the
# wire.  Leaving a URL blank skips registration for that worker;
# Mela still boots, it just won't have that worker available.
# Mela Task Radar (MCP-over-HTTP).  health is base_url + /health?deep=true.
TASK_RADAR_BASE_URL=
TASK_RADAR_MCP_API_KEY=
# Inbound API key Task Radar presents on /api/v1/ingest/* callbacks.
# In production reference Key Vault, e.g.:
#   TASK_RADAR_INBOUND_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/TASK-RADAR-INBOUND-API-KEY/)
TASK_RADAR_INBOUND_API_KEY=
# Public base URL workers POST their callbacks to (must be reachable from the worker).
# Local dev: http://localhost:8000   Prod: https://armely-ai-api.azurewebsites.net
MELA_INGESTION_BASE_URL=

# Meeting Assistant worker (Phase 4). Leave blank to skip registration.
MEETING_ASSISTANT_BASE_URL=
MEETING_ASSISTANT_MCP_API_KEY=
# Inbound API key Meeting Assistant presents on /api/v1/ingest/* callbacks.
# Production: MEETING_ASSISTANT_INBOUND_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/MEETING-ASSISTANT-INBOUND-API-KEY/)
MEETING_ASSISTANT_INBOUND_API_KEY=

# Knowledge Base index for hybrid vector search (Phase 4).
# Blank → KnowledgeStore falls back to SQL keyword search.
AZURE_SEARCH_KB_INDEX=

# Default TTL (in days) for Knowledge Base entries. Per-type overrides
# (e.g. goal_result=7, meeting_summary=60) live in knowledge.py.
KB_DEFAULT_EXPIRY_DAYS=30

# Phase 6B: comma-separated origins permitted to iframe Mela.
# Blank → SAMEORIGIN only.  Example: https://taskradar.armely.com,https://meet.armely.com
MELA_EMBED_ALLOWED_ORIGINS=

# Phase 6C: shared secret for worker self-registration.
# Blank → POST /api/v1/orchestration/register returns 503.
# Workers present this in the X-Registration-Key header.
MELA_WORKER_REGISTRATION_KEY=
