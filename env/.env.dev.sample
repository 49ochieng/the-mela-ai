# ============================================================
# Mela AI — Azure Dev Deployment  |  SAMPLE TEMPLATE
# Copy to .env.dev and fill in real values, OR paste each key
# directly into Azure App Service → Configuration → App Settings.
# NEVER commit .env.dev with real values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── JWT ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-random-64-char-hex-string>

# ── Dev Login ─────────────────────────────────────────────────
# Set ENABLE_DEV_LOGIN=false once a real admin account works via MSAL.
# The /auth/dev-login endpoint returns 404 when this is false.
ENABLE_DEV_LOGIN=true
DEV_USERNAME=<dev-username>
DEV_PASSWORD=<dev-password>

# ── Bootstrap admins ───────────────────────────────────────────
# Comma-separated Entra emails to auto-elevate to admin on first login.
# Resolved server-side from the validated JWT preferred_username claim.
# Audit-logged once. Remove this var after your first admin is confirmed.
BOOTSTRAP_ADMIN_EMAILS=edgar.mcochieng@armely.com

# ── Entra ID — shared tenant ──────────────────────────────────
AZURE_TENANT_ID=<azure-ad-tenant-id>

# ── App registration 1: Login / Auth (user sign-in) ──────────
# Create a NEW app registration in Entra ID dedicated to user authentication.
# Portal: App registrations → New registration
#   Supported account types: Accounts in this organizational directory only
#   Platform: Single-page application (SPA)
#   Redirect URIs (SPA): http://localhost:3005
#                        https://armely-ai-web.azurewebsites.net/
# After creation:
#   Expose an API → add scope: access_as_user  (App ID URI: api://<client-id>)
#   API permissions (delegated): openid, profile, email, User.Read
ENTRA_AUTH_CLIENT_ID=<login-app-registration-client-id>
# ENTRA_AUTH_CLIENT_SECRET is only needed if OBO flow is added server-side.
# Leave blank for a pure SPA with no server-side token exchange.
ENTRA_AUTH_CLIENT_SECRET=

# ── App registration 2: Enterprise data / Graph connectors ────
# This is the EXISTING app registration used by SharePoint/OneDrive connectors
# for app-only (client-credentials) token acquisition.  Do NOT change it.
# Portal: App registrations → <existing connector app>
#   Application permissions: Sites.Read.All, Files.Read.All, Mail.Send, etc.
AZURE_CLIENT_ID=<data-app-registration-client-id>
AZURE_CLIENT_SECRET=<data-app-registration-client-secret>
GRAPH_SCOPES=https://graph.microsoft.com/.default

# ── Azure AI Foundry (unified LLM endpoint) ──────────────────
AI_FOUNDRY_ENDPOINT=https://<your-project>.cognitiveservices.azure.com/
AI_FOUNDRY_API_KEY=<ai-foundry-api-key>
AI_FOUNDRY_API_VERSION=2024-05-01-preview

# ── Azure OpenAI (usually same endpoint as AI Foundry) ───────
AZURE_OPENAI_ENDPOINT=https://<your-project>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<same-as-ai-foundry-api-key>
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_FAST_DEPLOYMENT=Kimi-K2.5
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4.1

# ── Named model deployments (all on the same AI Foundry endpoint) ─
DEPLOYMENT_GPT52_CHAT=gpt-5.2-chat
DEPLOYMENT_GPT41=gpt-4.1
DEPLOYMENT_KIMI_K25=Kimi-K2.5
DEPLOYMENT_MISTRAL_LARGE_3=Mistral-Large-3
DEPLOYMENT_DEEPSEEK_V32=DeepSeek-V3.2
DEPLOYMENT_LLAMA4_MAVERICK=Llama-4-Maverick-17B-128E-Instruct-FP8
# Upgraded embedding model — 3072 dims, higher quality than text-embedding-3-small
DEPLOYMENT_EMBEDDING=text-embedding-3-large

# ── GPT-4o (optional separate resource) ─────────────────────
GPT4O_ENDPOINT=https://<gpt4o-resource>.cognitiveservices.azure.com
GPT4O_API_KEY=<gpt4o-api-key>
GPT4O_DEPLOYMENT=gpt-4o

# ── Anthropic Claude (limited preview) ───────────────────────
# Store the key in Azure Key Vault for production; use env/.env.local for dev.
# NEVER commit a real key to source control.
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_ENABLED=true
ANTHROPIC_RPM_LIMIT=3
ANTHROPIC_MAX_TOKENS_SONNET=4096
ANTHROPIC_MAX_TOKENS_HAIKU=2048

# ── Image Generation ─────────────────────────────────────────
# Primary: FLUX.1-Kontext-pro
FLUX_ENDPOINT=https://mela-dall-e-resource.cognitiveservices.azure.com
FLUX_API_KEY=<flux-api-key>
FLUX_DEPLOYMENT=FLUX.1-Kontext-pro
FLUX_API_VERSION=2024-05-01-preview
IMAGE_PROVIDER_ORDER=flux,dalle

# Fallback: DALL-E 3 (leave blank if deployment is deprecated)
AZURE_DALLE_ENDPOINT=https://<dalle-resource>.openai.azure.com
AZURE_DALLE_API_KEY=<dalle-api-key>
AZURE_DALLE_API_VERSION=2024-04-01-preview
AZURE_DALLE_DEPLOYMENT=dall-e-3

# ── Azure Document Intelligence ───────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<doc-intel>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<doc-intel-key>

# ── Azure Speech ──────────────────────────────────────────────
AZURE_SPEECH_KEY=<speech-key>
AZURE_SPEECH_ENDPOINT=https://<speech-resource>.cognitiveservices.azure.com/
AZURE_SPEECH_REGION=eastus

# ── Azure Translator ──────────────────────────────────────────
AZURE_TRANSLATOR_KEY=<translator-key>
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_REGION=eastus

# ── Azure AI Search ──────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=<admin-key>
AZURE_SEARCH_QUERY_KEY=<query-key>
AZURE_SEARCH_INDEX_NAME=fileshare-documents
AZURE_SEARCH_VECTOR_INDEX_NAME=fileshare-vector-documents
AZURE_SEARCH_CACHE_INDEX_NAME=mela-query-cache

# ── Azure SQL ─────────────────────────────────────────────────
AZURE_SQL_SERVER=<sql-server>.database.windows.net
AZURE_SQL_DATABASE=mela-dev
AZURE_SQL_USERNAME=<sql-admin-user>
AZURE_SQL_PASSWORD=<sql-admin-password>

# ── Azure Storage ─────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# ── Azure Speech ──────────────────────────────────────────────
AZURE_SPEECH_KEY=<speech-key>
AZURE_SPEECH_REGION=eastus

# ── Azure DALL-E (legacy duplicate block — remove if not used) ──
AZURE_DALLE_ENDPOINT=https://<your-project>.openai.azure.com/
AZURE_DALLE_API_KEY=<dalle-api-key>

# ── Azure Document Intelligence ───────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<doc-intel>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<doc-intel-key>

# ── SharePoint / OneDrive ────────────────────────────────────
SHAREPOINT_SITES=<comma-separated-site-urls>
ONEDRIVE_ROOT=https://<tenant>-my.sharepoint.com/

# ── Organisation Website ──────────────────────────────────────
ORG_WEBSITE_ALLOWLIST=<comma-separated-domains>
ORG_WEBSITE_CRAWL_DEPTH=3

# ── Connector Feature Flags ───────────────────────────────────
CONNECTOR_SHAREPOINT_ENABLED=true
CONNECTOR_ONEDRIVE_ENABLED=true
CONNECTOR_EMAIL_ENABLED=false
CONNECTOR_PLANNER_ENABLED=true
CONNECTOR_ORG_WEBSITE_ENABLED=true
CONNECTOR_PUBLIC_WEB_ENABLED=false

# ── Orchestration Brain — registered worker apps ─────────────
# Mela Task Radar (MCP-over-HTTP). Leave blank to skip registration.
TASK_RADAR_BASE_URL=https://<task-radar-host>/mcp
TASK_RADAR_MCP_API_KEY=<task-radar-mcp-api-key>
# Inbound API key Task Radar presents on /api/v1/ingest/* callbacks.
# Production: TASK_RADAR_INBOUND_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/TASK-RADAR-INBOUND-API-KEY/)
TASK_RADAR_INBOUND_API_KEY=<task-radar-inbound-api-key>
# Public base URL workers POST callbacks to.
MELA_INGESTION_BASE_URL=https://<your-dev-app>.azurewebsites.net

# Meeting Assistant worker (Phase 4). Leave blank to skip registration.
MEETING_ASSISTANT_BASE_URL=
MEETING_ASSISTANT_MCP_API_KEY=
MEETING_ASSISTANT_INBOUND_API_KEY=

# Knowledge Base index for hybrid vector search (Phase 4). Blank → SQL fallback.
AZURE_SEARCH_KB_INDEX=mela-kb-entries
KB_DEFAULT_EXPIRY_DAYS=30

# Redis — shared state across replicas + alert-cooldown dedup. Blank → in-process.
# Reference the Key Vault secret written by infra/modules/redis.bicep, e.g.
# REDIS_URL=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/redis-connection-string/)
REDIS_URL=

# Phase 6B: comma-separated origins permitted to iframe Mela.  Blank → SAMEORIGIN only.
MELA_EMBED_ALLOWED_ORIGINS=

# Phase 6C: shared secret for worker self-registration.  Blank disables /orchestration/register.
MELA_WORKER_REGISTRATION_KEY=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["https://<your-dev-app>.azurewebsites.net","http://localhost:3000"]

# ── Application Insights ──────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...
