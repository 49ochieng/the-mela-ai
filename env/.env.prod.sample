# ============================================================
# Mela AI — Production  |  SAMPLE TEMPLATE
# In production, set these as Azure App Service Application Settings
# or reference them from Azure Key Vault using @Microsoft.KeyVault(...)
# NEVER commit a .env.prod file with real values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# ── JWT ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Store in Azure Key Vault, reference as @Microsoft.KeyVault(SecretUri=...)
JWT_SECRET_KEY=<generate-a-random-64-char-hex-string>

# ── Dev Login — DISABLED in production ────────────────────────
# Must be false in prod. Endpoint returns 404 when false.
ENABLE_DEV_LOGIN=false

# ── Bootstrap admins ───────────────────────────────────────────
# Set once to promote first admin. Remove after confirmation.
# BOOTSTRAP_ADMIN_EMAILS=edgar.mcochieng@armely.com

# ── Entra ID — shared tenant ──────────────────────────────────
AZURE_TENANT_ID=<azure-ad-tenant-id>

# ── App registration 1: Login / Auth (user sign-in) ──────────
# Dedicated SPA app registration for user authentication.
# Redirect URIs (SPA platform): https://armely-ai-web.azurewebsites.net/
# Expose an API scope: api://<client-id>/access_as_user
# Delegated permissions: openid, profile, email, User.Read
ENTRA_AUTH_CLIENT_ID=<login-app-registration-client-id>
ENTRA_AUTH_CLIENT_SECRET=  # leave blank unless OBO flow is implemented

# ── App registration 2: Enterprise data / Graph connectors ────
# App-only access for SharePoint/OneDrive connectors (client credentials flow).
# Application permissions: Sites.Read.All, Files.Read.All
AZURE_CLIENT_ID=<data-app-registration-client-id>
AZURE_CLIENT_SECRET=<data-app-secret-from-keyvault>
GRAPH_SCOPES=https://graph.microsoft.com/.default
# Fallback sender UPN for app-only email (if no delegated token is available)
GRAPH_SENDER_EMAIL=
# Default Planner plan ID — used by AI tools when user doesn't specify a plan
# Find via Graph Explorer: GET /groups/{groupId}/planner/plans
GRAPH_DEFAULT_PLANNER_PLAN_ID=

# ── Azure AI Foundry / OpenAI ────────────────────────────────
AI_FOUNDRY_ENDPOINT=https://<your-project>.openai.azure.com/
AI_FOUNDRY_API_KEY=<ai-foundry-api-key-from-keyvault>
AZURE_OPENAI_ENDPOINT=https://<your-project>.openai.azure.com/
AZURE_OPENAI_API_KEY=<ai-foundry-api-key-from-keyvault>

# ── Named model deployments ───────────────────────────────────
DEPLOYMENT_GPT52_CHAT=gpt-5.2-chat
DEPLOYMENT_GPT41=gpt-4.1
DEPLOYMENT_KIMI_K25=Kimi-K2.5
DEPLOYMENT_MISTRAL_LARGE_3=Mistral-Large-3
DEPLOYMENT_DEEPSEEK_V32=DeepSeek-V3.2
DEPLOYMENT_LLAMA4_MAVERICK=Llama-4-Maverick-17B-128E-Instruct-FP8
DEPLOYMENT_EMBEDDING=text-embedding-3-large

# ── Anthropic Claude (limited preview) ───────────────────────
# Store in Key Vault: @Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/ANTHROPIC-API-KEY/)
ANTHROPIC_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault-name>.vault.azure.net/secrets/ANTHROPIC-API-KEY/)
ANTHROPIC_ENABLED=true
ANTHROPIC_RPM_LIMIT=3
ANTHROPIC_MAX_TOKENS_SONNET=4096
ANTHROPIC_MAX_TOKENS_HAIKU=2048

# ── Azure AI Search ──────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=<admin-key-from-keyvault>
AZURE_SEARCH_QUERY_KEY=<query-key-from-keyvault>
AZURE_SEARCH_INDEX_NAME=fileshare-documents
AZURE_SEARCH_VECTOR_INDEX_NAME=fileshare-vector-documents
AZURE_SEARCH_CACHE_INDEX_NAME=mela-query-cache

# ── Azure SQL ─────────────────────────────────────────────────
AZURE_SQL_SERVER=<sql-server>.database.windows.net
AZURE_SQL_DATABASE=mela-prod
AZURE_SQL_USERNAME=<sql-admin-user>
AZURE_SQL_PASSWORD=<sql-admin-password-from-keyvault>

# ── Azure Storage ─────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# ── Azure Speech ──────────────────────────────────────────────
AZURE_SPEECH_KEY=<speech-key-from-keyvault>
AZURE_SPEECH_REGION=eastus

# ── Azure DALL-E ─────────────────────────────────────────────
AZURE_DALLE_ENDPOINT=https://<your-project>.openai.azure.com/
AZURE_DALLE_API_KEY=<dalle-api-key-from-keyvault>

# ── Azure Document Intelligence ───────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<doc-intel>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<doc-intel-key-from-keyvault>

# ── SharePoint / OneDrive ────────────────────────────────────
SHAREPOINT_SITES=<comma-separated-site-urls>
ONEDRIVE_ROOT=https://<tenant>-my.sharepoint.com/

# ── Organisation Website ──────────────────────────────────────
ORG_WEBSITE_ALLOWLIST=<comma-separated-domains>
ORG_WEBSITE_CRAWL_DEPTH=3

# ── Connector Feature Flags ───────────────────────────────────
CONNECTOR_SHAREPOINT_ENABLED=true
CONNECTOR_ONEDRIVE_ENABLED=true
CONNECTOR_EMAIL_ENABLED=true
CONNECTOR_PLANNER_ENABLED=true
CONNECTOR_ORG_WEBSITE_ENABLED=true
CONNECTOR_PUBLIC_WEB_ENABLED=false

# ── Orchestration Brain — registered worker apps ─────────────
# Mela Task Radar (MCP-over-HTTP). Leave blank to skip registration.
TASK_RADAR_BASE_URL=https://<task-radar-host>/mcp
TASK_RADAR_MCP_API_KEY=<task-radar-mcp-api-key>
# Inbound API key Task Radar presents on /api/v1/ingest/* callbacks.
TASK_RADAR_INBOUND_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault-name>.vault.azure.net/secrets/TASK-RADAR-INBOUND-API-KEY/)
# Public base URL workers POST callbacks to (Mela API public URL).
MELA_INGESTION_BASE_URL=https://armely-ai-api.azurewebsites.net

# Meeting Assistant worker (Phase 4). Leave blank to skip registration.
MEETING_ASSISTANT_BASE_URL=https://<meeting-assistant-host>/mcp
MEETING_ASSISTANT_MCP_API_KEY=<meeting-assistant-mcp-api-key>
MEETING_ASSISTANT_INBOUND_API_KEY=@Microsoft.KeyVault(SecretUri=https://<vault-name>.vault.azure.net/secrets/MEETING-ASSISTANT-INBOUND-API-KEY/)

# Knowledge Base index for hybrid vector search (Phase 4).
AZURE_SEARCH_KB_INDEX=mela-kb-entries
KB_DEFAULT_EXPIRY_DAYS=30

# Phase 6B: comma-separated origins permitted to iframe Mela.  Blank → SAMEORIGIN only.
MELA_EMBED_ALLOWED_ORIGINS=https://<embedding-app-1>,https://<embedding-app-2>

# Phase 6C: shared secret for worker self-registration.  Source from Key Vault.
MELA_WORKER_REGISTRATION_KEY=@Microsoft.KeyVault(SecretUri=https://<vault-name>.vault.azure.net/secrets/MELA-WORKER-REGISTRATION-KEY/)

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["https://<your-domain>"]

# ── Application Insights ──────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...

# ── Azure Key Vault ───────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
